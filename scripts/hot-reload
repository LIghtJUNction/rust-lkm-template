#!/usr/bin/env bash
# SPDX-License-Identifier: GPL-2.0

## Hot-reload script for Rust LKM Template
## Watches for changes and automatically rebuilds and runs

set -euo pipefail
IFS=$'\n\t'

readonly SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
readonly KERNEL="${KERNEL:-../linux}"
readonly BUSYBOX="${BUSYBOX:-../busybox}"

check_deps() {
    if ! command -v cargo-watch &>/dev/null; then
        printf "Error: cargo-watch is required. Install with: cargo install cargo-watch\\n" >&2
        exit 1
    fi
}

main() {
    check_deps

    printf "Watching for changes in *.rs, Makefile, Kbuild, and scripts/...\\n"

    local watch_sources=(
        "-w" "Makefile"
        "-w" "Kbuild"
        "-w" "./scripts"
    )

    # Add all .rs files to watch list
    while IFS= read -r -d '' file; do
        watch_sources+=("-w" "$file")
    done < <(find . -name "*.rs" -print0)

    cargo watch --poll -q -c -N \
        -s "./scripts/build && ./scripts/run && ./scripts/build -t clean" \
        "${watch_sources[@]}"
}

main "$@"
