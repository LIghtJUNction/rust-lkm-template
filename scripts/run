#!/usr/bin/env bash
# SPDX-License-Identifier: GPL-2.0

## Run script for Rust LKM Template
## Spins up QEMU with the compiled kernel module

set -euo pipefail
IFS=$'\n\t'

readonly SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
readonly KERNEL="${KERNEL:-../linux}"
readonly BUSYBOX="${BUSYBOX:-../busybox}"

usage() {
    cat <<EOF
Usage: ${0##*/} [-k <kernel-dir>] [-b <busybox-dir>]

Options:
    -k KERNEL    Path to rust-enabled kernel (default: ../linux)
    -b BUSYBOX   Path to built busybox (default: ../busybox)
EOF
    exit 1
}

check_deps() {
    local deps=(qemu-system-x86_64 cpio gzip)
    for cmd in "${deps[@]}"; do
        if ! command -v "$cmd" &>/dev/null; then
            printf "Error: '%s' is required but not installed.\\n" "$cmd" >&2
            exit 1
        fi
    done
}

main() {
    local kernel="$KERNEL"
    local busybox="$BUSYBOX"

    while getopts ":k:b:h" opt; do
        case "$opt" in
            k) kernel="$OPTARG" ;;
            b) busybox="$OPTARG" ;;
            h) usage ;;
            :) printf "Option -%s requires an argument\\n" "$OPTARG" >&2; exit 1 ;;
            *) printf "Invalid option: -%s\\n" "$OPTARG" >&2; exit 1 ;;
        esac
    done

    check_deps

    local install_dir="${busybox}/_install"
    if [[ ! -d "$install_dir" ]]; then
        printf "Error: BusyBox install directory not found: %s\\n" "$install_dir" >&2
        exit 1
    fi

    printf "Copying .ko files to initramfs...\\n"
    while IFS= read -r ko; do
        cp "$ko" "$install_dir/"
    done < <(find . -name "*.ko" 2>/dev/null || true)

    printf "Generating initramfs...\\n"
    pushd "$install_dir" > /dev/null || exit 1
    find . -print0 | cpio -o -H newc --null | gzip -9 > "../initramfs.img"
    popd > /dev/null || exit 1

    printf "Starting QEMU...\\n"
    exec qemu-system-x86_64 \
        -kernel "${kernel}/vmlinux" \
        -append "console=ttyS0,115200 root=/dev/ram0 loglevel=3" \
        -initrd "${busybox}/initramfs.img" \
        -nographic \
        -machine q35 \
        -enable-kvm \
        -device intel-iommu \
        -cpu host \
        -m 1G \
        -nic user,model=rtl8139,hostfwd=tcp::5555-:23,hostfwd=tcp::5556-:8080
}

main "$@"
